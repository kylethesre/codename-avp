[gd_scene format=3 uid="uid://cdrqql6g8e2bv"]

[sub_resource type="GDScript" id="GDScript_oofok"]
script/source = "extends CanvasLayer

func _ready():
	#Make sure the menu is hidden when the game starts
	hide()

func _input(event):
	# ESC key (\"pause\" action)
	if event.is_action_pressed(\"pause\"):
		print(\"ESC paused the game\")
		toggle_pause()

func toggle_pause():
	# Flip the current pause state
	var is_paused = get_tree().paused
	get_tree().paused = !is_paused
	
	# Show or hide the menu based on the new state
	visible = get_tree().paused
	
	if visible:
		update_upgrades_list()

func update_upgrades_list():
	var list_container = $ColorRect/HBoxContainer/ScrollContainer/UpgradeList
	if not list_container: return
	
	for child in list_container.get_children():
		child.queue_free()
		
	var title = Label.new()
	title.text = \"Acquired Upgrades:\"
	title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	list_container.add_child(title)
	
	var mgr = null
	var main = get_tree().current_scene
	if main and main.has_node(\"UpgradeManager\"):
		mgr = main.get_node(\"UpgradeManager\")
	elif get_tree().root.has_node(\"UpgradeManager\"):
		mgr = get_tree().root.get_node(\"UpgradeManager\")
		
	if not mgr: return
	
	var counts = {}
	for u_id in mgr.obtained_upgrades:
		if counts.has(u_id):
			counts[u_id] += 1
		else:
			counts[u_id] = 1
			
	for u_id in counts.keys():
		var display_name = u_id
		for upg in mgr.all_upgrades:
			if upg.id == u_id:
				display_name = upg.name
				break
				
		var amt = counts[u_id]
		var l = Label.new()
		if amt > 1:
			l.text = \"- \" + display_name + \" x\" + str(amt)
		else:
			l.text = \"- \" + display_name
		list_container.add_child(l)

func _on_resume_button_pressed() -> void:
	#Resume unpauses game
	toggle_pause()

func _on_quit_button_pressed() -> void:
	#quit takes you back to main menu
	get_tree().paused = false
	#load main menu scene
	get_tree().change_scene_to_file(\"res://scenes/main_menu.tscn\")

func _on_volume_slider_value_changed(value: float) -> void:
	#Find ID for main audio channel
	var bus_index = AudioServer.get_bus_index(\"Master\")
	#Convert 0-1 slider into decibels
	AudioServer.set_bus_volume_db(bus_index, linear_to_db(value))

func _on_sfx_value_changed(value: float) -> void:
	#Find ID for SFX audio channel
	var bus_index = AudioServer.get_bus_index(\"SFX\")
	#Convert 0-1 slider into decibels
	AudioServer.set_bus_volume_db(bus_index, linear_to_db(value))
"

