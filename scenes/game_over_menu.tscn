[sub_resource type="GDScript" id="GDScript_tg6a4"]
script/source = "extends CanvasLayer

@onready var restart_button = $RestartButton 
# Add a reference to your main UI container
# Make sure the name matches what is in your scene tree!
@onready var menu_container = $TextureRect 

func _ready() -> void:
	hide() 
	process_mode = Node.PROCESS_MODE_ALWAYS
	
	# Start the container fully transparent
	if menu_container:
		menu_container.modulate.a = 0.0 

func show_game_over() -> void:
	show()
	Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
	get_tree().paused = true
	print(\"Game paused: \", get_tree().paused)
	
	#Create a smooth fade-in effect targeting the menu container, NOT self
	var tween = create_tween()
	tween.set_pause_mode(Tween.TWEEN_PAUSE_PROCESS) 
	if menu_container:
		tween.tween_property(menu_container, \"modulate:a\", 1.0, 0.5) 
	
	#Grab focus for keyboard support
	if restart_button:
		restart_button.grab_focus()

func _on_restart_pressed() -> void:
	get_tree().paused = false 
	get_tree().reload_current_scene()
"

