[gd_scene format=3 uid="uid://cdrqql6g8e2bv"]

[sub_resource type="GDScript" id="GDScript_oofok"]
script/source = "extends CanvasLayer

func _ready():
	#Make sure the menu is hidden when the game starts
	hide()

func _input(event):
	# ESC key (\"pause\" action)
	if event.is_action_pressed(\"pause\"):
		print(\"ESC paused the game\")
		toggle_pause()

func toggle_pause():
	# Flip the current pause state
	var is_paused = get_tree().paused
	get_tree().paused = !is_paused
	
	# Show or hide the menu based on the new state
	visible = get_tree().paused

func _on_resume_button_pressed() -> void:
	#Resume unpauses game
	toggle_pause()


func _on_quit_button_pressed() -> void:
	#quit takes you back to main menu
	get_tree().paused = false
	#load main menu scene
	get_tree().change_scene_to_file(\"res://scenes/main_menu.tscn\")


func _on_volume_slider_value_changed(value: float) -> void:
	#Find ID for main audio channel
	var bus_index = AudioServer.get_bus_index(\"Master\")
	#Convert 0-1 slider into decibels
	AudioServer.set_bus_volume_db(bus_index, linear_to_db(value))


func _on_sfx_value_changed(value: float) -> void:
	#Find ID for SFX audio channel
	var bus_index = AudioServer.get_bus_index(\"SFX\")
	#Convert 0-1 slider into decibels
	AudioServer.set_bus_volume_db(bus_index, linear_to_db(value))
"

